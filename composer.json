{
    "name": "snowman/ai",
    "description": "PHP AI SDK - 统一多驱动 AI 接入，标准化 DTO 响应",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "ai",
        "claude",
        "openai",
        "deepseek",
        "laravel",
        "sdk"
    ],
    "authors": [
        {
            "name": "SnowmanNunu",
            "email": "snowmannunu@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "SnowmanNunu\\Ai\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SnowmanNunu\\Ai\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:coverage": "phpunit --coverage-html coverage/",
        "lint": "pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "SnowmanNunu\\Ai\\Laravel\\AiServiceProvider"
            ],
            "aliases": {
                "Ai": "SnowmanNunu\\Ai\\Laravel\\Facades\\Ai"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
